apiVersion: cloud.google.com/v1
kind: BackendConfig
metadata:
  name: django-backendconfig
  namespace: todo-app
spec:
  healthCheck:
    checkIntervalSec: 15
    timeoutSec: 10
    healthyThreshold: 1
    unhealthyThreshold: 2
    type: HTTP
    requestPath: /accounts/login/    # ← returns 200, no redirect
    port: 8000
